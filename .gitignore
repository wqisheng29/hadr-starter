# Generated reports — the morning routine rebuilds these; do not commit churn.
reports/
*.sitrep.html

# dashboard.html is the exception: it is the product, and it is committed.
!dashboard.html

# Secrets stay out of the repo and out of the agent's context.
.env
.env.*

# Language debris — extend for whichever toolchain you pick in CLAUDE.md.
__pycache__/
.venv/
node_modules/
.DS_Store
*.egg-info/

# Slice 7: state/ is now COMMITTED (ADR-0006). The single-writer / commit-on-change
# coordination has landed (scripts/commit_state.py), so the ledger and the readable
# published snapshots are durable committed state each tick reads/writes — no longer
# produced-only artifacts. Ignore only SQLite's transient sidecar files.
state/*.db-wal
state/*.db-shm
state/*.db-journal
