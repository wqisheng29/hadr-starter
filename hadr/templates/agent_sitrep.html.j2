{#
  Agent-authored situation report. Distinct from dashboard.html (the
  deterministic pipeline's product): this page shows the *model's* assessed
  events, so autoescape matters twice over — both feed text and model output are
  untrusted here.
#}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ headline }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
         max-width: 820px; margin: 0 auto; padding: 40px 24px; line-height: 1.5; color: #1a1a1a; }
  h1 { font-size: 1.5rem; margin: 0 0 4px; }
  .as-of { color: #5b5b57; font-size: 0.9rem; margin: 0 0 24px; }
  .event { border-bottom: 1px solid #e4e2dd; padding: 14px 0; }
  .event h2 { font-size: 1.05rem; margin: 0 0 4px; }
  .meta { color: #5b5b57; font-size: 0.85rem; margin: 0 0 6px; }
  .mag { font-variant-numeric: tabular-nums; font-weight: 600; }
  .assessment { margin: 0; }
  .empty { color: #5b5b57; font-style: italic; }
</style>
</head>
<body>
<header>
  <h1>{{ headline }}</h1>
  <p class="as-of">as of {{ as_of }}</p>
</header>

<section class="events">
{% if events %}
  {% for e in events %}
  <article class="event">
    <h2>{{ e.title }}</h2>
    <p class="meta">
      {% if e.magnitude is not none %}<span class="mag">M{{ "%.1f"|format(e.magnitude) }}</span>{% endif %}
      {% if e.place %}· {{ e.place }}{% endif %}
    </p>
    <p class="assessment">{{ e.assessment }}</p>
  </article>
  {% endfor %}
{% else %}
  <p class="empty">No events assessed.</p>
{% endif %}
</section>
</body>
</html>
