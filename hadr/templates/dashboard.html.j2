{#
  Dashboard. A header with the "as of" line, optional feed banners, then the
  events: material/confirmed quakes are HEADLINED in the main table (each with a
  provisional/confirmed marker), and routine ones fold into a collapsed summary
  below the fold (Slice 3). Classification is decided in the briefer from config
  thresholds — the template only iterates the two lists it is handed.
#}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>HADR earthquake monitor</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
         max-width: 820px; margin: 0 auto; padding: 40px 24px; line-height: 1.5; color: #1a1a1a; }
  h1 { font-size: 1.5rem; margin: 0 0 4px; }
  .as-of { color: #5b5b57; font-size: 0.9rem; margin: 0 0 24px; }
  .banner { background: #fbe7e7; border-left: 4px solid #b30000; padding: 10px 16px;
            border-radius: 0 6px 6px 0; margin: 0 0 24px; font-size: 0.92rem; }
  table { border-collapse: collapse; width: 100%; }
  th, td { text-align: left; padding: 8px 10px; border-bottom: 1px solid #e4e2dd; vertical-align: top; }
  th { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #5b5b57; }
  td.mag { font-variant-numeric: tabular-nums; white-space: nowrap; }
  .empty { color: #5b5b57; font-style: italic; }
  .tag { font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
         letter-spacing: 0.04em; padding: 1px 6px; border-radius: 4px; white-space: nowrap; }
  .tag.provisional { background: #fff3e0; color: #9a5b00; }
  .tag.confirmed { background: #e6f4ea; color: #1b5e20; }
  .routine { margin-top: 32px; }
  .routine h2 { font-size: 0.95rem; color: #5b5b57; margin: 0 0 8px;
                text-transform: uppercase; letter-spacing: 0.04em; }
  .routine ul { list-style: none; padding: 0; margin: 0; }
  .routine li { padding: 4px 0; border-bottom: 1px solid #efeee9;
                color: #5b5b57; font-size: 0.9rem; }
  .routine .mag { font-variant-numeric: tabular-nums; color: #1a1a1a; }
</style>
</head>
<body>
<header>
  <h1>HADR earthquake monitor</h1>
  <p class="as-of">as of {{ as_of }}</p>
</header>

{% for b in feed_banners %}
<div class="banner">
  {{ b.label }} feed {{ b.state }}{% if b.detail %}: {{ b.detail }}{% endif %}.
  Showing the last known picture; it may be stale.
</div>
{% endfor %}

<section class="events">
{% if not events %}
  <p class="empty">No earthquakes at or above the materiality floor.</p>
{% else %}
  {% if headline %}
  <table>
    <thead>
      <tr><th>Title</th><th>Status</th><th>Magnitude</th><th>Place</th><th>Origin time (SGT)</th></tr>
    </thead>
    <tbody>
    {% for e in headline %}
      <tr>
        <td>{{ e.title if e.title is not none else "—" }}{% if e.sources|length > 1 %} <span style="font-size:0.7rem; color:#5b5b57; white-space:nowrap;">{{ e.sources_label }}</span>{% endif %}{% if e.gdacs_alert %} <span style="font-size:0.7rem; font-weight:600; color:{{ e.gdacs_alert_colour }};">{{ e.gdacs_alert }}</span>{% endif %}</td>
        <td>{% if e.is_confirmed %}<span class="tag confirmed">confirmed</span>{% else %}<span class="tag provisional">provisional</span>{% endif %}</td>
        <td class="mag">{{ "M%.1f"|format(e.magnitude) if e.magnitude is not none else "—" }}</td>
        <td>{{ e.place if e.place is not none else "—" }}</td>
        <td title="{{ e.origin_utc }}">{{ e.origin_sgt }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="empty">No material earthquakes right now.</p>
  {% endif %}

  {% if routine %}
  <section class="routine">
    <h2>Routine / ongoing ({{ routine|length }})</h2>
    <ul>
    {% for e in routine %}
      <li><span class="mag">{{ "M%.1f"|format(e.magnitude) if e.magnitude is not none else "—" }}</span> {{ e.title if e.title is not none else "—" }} — {{ e.place if e.place is not none else "—" }} <span class="tag {% if e.is_confirmed %}confirmed{% else %}provisional{% endif %}">{{ e.status }}</span></li>
    {% endfor %}
    </ul>
  </section>
  {% endif %}
{% endif %}
</section>
</body>
</html>
